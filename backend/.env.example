# ─────────────────────────────────────────────────────────────
# Lenzli waitlist backend — configuration
# Copy this file to ".env" and fill in the values.
# ─────────────────────────────────────────────────────────────

# Port the API listens on (default 8787)
PORT=8787

# Comma-separated list of allowed browser origins (the frontend URLs).
# In dev this is your Vite server. In prod, your real domain.
# Use * to allow any origin (fine for a public waitlist).
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Email sending (Resend — https://resend.com) ──
# Create a free account, add+verify a sending domain, then make an API key.
# Without this key the API still works and stores signups; it just skips
# sending the confirmation email (and logs a warning).
RESEND_API_KEY=

# The "From" address. MUST be on a domain you've verified in Resend.
# e.g. "Lenzli <hello@lenzli.com>"
FROM_EMAIL=Lenzli <onboarding@resend.dev>

# Optional: get an email yourself every time someone joins. Leave blank to disable.
NOTIFY_EMAIL=

# Optional: where replies to the confirmation email should go (e.g. your inbox).
# Lets you send from a no-reply-style address while still receiving replies.
REPLY_TO_EMAIL=

# Optional: protect the admin endpoints (GET /api/waitlist, /api/waitlist/count).
# Send it as the "x-admin-token" header. Leave blank to leave them open in dev.
ADMIN_TOKEN=
